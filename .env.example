# Copy to .env (do not commit .env)

SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_ID=

# Ollama (default matches campus setup; in Docker use host gateway if Ollama runs on VM host)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-coder:6.7b
OLLAMA_TIMEOUT=120

CHROMA_PERSIST_DIR=./chroma_db
CHROMA_N_RESULTS=5
# CHROMA_FILTER_TO_PROJECTS_TABLE=true

LOG_LEVEL=INFO
