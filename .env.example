# Copy to .env (do not commit .env)

SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_ID=

# Ollama — local on the VM/host.
# Docker Compose: omit OLLAMA_BASE_URL (defaults to host.docker.internal:11434).
# Plain `python main.py` on the host: uncomment next line.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

CHROMA_PERSIST_DIR=./chroma_db
CHROMA_N_RESULTS=5
# CHROMA_FILTER_TO_PROJECTS_TABLE=true

LOG_LEVEL=INFO
